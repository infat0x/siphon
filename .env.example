# ==========================================
# SIPHON AI INTEGRATION CONFIGURATION
# ==========================================
# To use the AI summary feature, select one of the providers below,
# uncomment its lines, and insert your API key. Make sure only ONE 
# provider block is active at a time.

# ------------------------------------------
# 1. OpenAI (Default)
# ------------------------------------------
# AI_API_KEY=sk-your-openai-api-key
# AI_MODEL=gpt-4o-mini
# AI_API_URL=https://api.openai.com/v1/chat/completions

# ------------------------------------------
# 2. DeepSeek
# ------------------------------------------
# AI_API_KEY=sk-your-deepseek-api-key
# AI_MODEL=deepseek-chat
# AI_API_URL=https://api.deepseek.com/chat/completions

# ------------------------------------------
# 3. Mistral AI
# ------------------------------------------
# AI_API_KEY=your-mistral-api-key
# AI_MODEL=mistral-large-latest
# AI_API_URL=https://api.mistral.ai/v1/chat/completions

# ------------------------------------------
# 4. Anthropic (Claude) via Proxy/LiteLLM
# Note: Since Siphon uses the OpenAI API standard, to use Claude 
# you must use an OpenAI-compatible proxy (like LiteLLM or OpenRouter).
# ------------------------------------------
# AI_API_KEY=your-openrouter-or-proxy-key
# AI_MODEL=anthropic/claude-3.5-sonnet
# AI_API_URL=https://openrouter.ai/api/v1/chat/completions

# ------------------------------------------
# 5. Groq (Ultra-fast Open-Source Models)
# ------------------------------------------
# AI_API_KEY=gsk_your_groq_api_key
# AI_MODEL=llama-3.1-70b-versatile
# AI_API_URL=https://api.groq.com/openai/v1/chat/completions

# ------------------------------------------
# 6. Local LLM (Ollama)
# ------------------------------------------
# AI_API_KEY=ollama
# AI_MODEL=llama3
# AI_API_URL=http://localhost:11434/v1/chat/completions
